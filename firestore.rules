rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários — só o próprio usuário lê, só admin escreve
    match /usuarios/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // só via Firebase Console ou Admin SDK
    }

    // Eventos — dono lê/escreve tudo; qualquer um pode adicionar/remover fotos (upload público)
    match /eventos/{uid} {
      // Dono autenticado tem acesso total
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Upload público: permite adicionar/remover URLs do array photos
      allow update: if
        request.resource.data.keys().hasOnly(['photos']) &&
        request.resource.data.photos is list;
    }
  }
}
