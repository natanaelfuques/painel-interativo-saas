rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários — leitura só pelo próprio usuário autenticado
    match /usuarios/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // só via admin/membros.html com SDK admin
    }

    // Eventos — leitura/escrita pelo dono do evento
    match /eventos/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Presencas — totem escreve sem autenticação (tela pública)
      match /presencas/{sessionId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if true;  // totem abre sem login
        allow delete: if true;  // totem remove ao fechar
        allow update: if true;  // heartbeat
      }
    }

  }
}
